{
  "name": "@orion/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
  ".": "./src/index.ts",
  "./schema": "./src/schema/index.ts",
  "./services/org-provisioning": "./src/services/org-provisioning.ts",
  "./lib/token-encryption": "./src/lib/token-encryption.ts"
},
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/seed/index.ts",
    "db:seed:reset": "tsx src/seed/reset.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
