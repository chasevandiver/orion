# =============================================================================
# ORION AI Marketing OS — Environment Variables
# =============================================================================
#
# Usage:
#   cp .env.example .env.local
#   # Fill in values, then run: npm run validate-env
#
# NEVER commit .env.local to version control.
#
# Labels:
#   [REQUIRED]     App will not start or core features will completely break.
#   [RECOMMENDED]  Major features disabled without this (graceful fallback exists).
#   [OPTIONAL]     Nice-to-have; described fallback activates automatically.
#
# Validation: npm run validate-env
# =============================================================================


# ═══════════════════════════════════════════════════════════════════════════════
# APP URLS
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Frontend public URL — used in OAuth redirect URIs, share links, emails
NEXT_PUBLIC_APP_URL=http://localhost:3000

# [REQUIRED] Internal Express API URL — used by Next.js server components and Inngest
# In production set this to an internal hostname to avoid public internet round-trips
INTERNAL_API_URL=http://localhost:3001

# [OPTIONAL] Public-facing API URL — used in pipeline for compositor callback
# Defaults to INTERNAL_API_URL if unset. Set explicitly in production.
PUBLIC_API_URL=http://localhost:3001

# [OPTIONAL] API base URL for OAuth callback construction in integrations
# Without this: social OAuth redirects may fail in production
API_BASE_URL=http://localhost:3001

# [OPTIONAL] Web base URL for OAuth success/failure redirect
# Without this: social OAuth post-connect redirect may fail
WEB_BASE_URL=http://localhost:3000

# [OPTIONAL] API server port
# Without this: Express defaults to port 3001
PORT=3001

# [OPTIONAL] Log verbosity: error | warn | info | debug
LOG_LEVEL=info


# ═══════════════════════════════════════════════════════════════════════════════
# AUTH
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] next-auth session encryption key
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING

# [REQUIRED] Canonical URL for next-auth redirects
NEXTAUTH_URL=http://localhost:3000

# [REQUIRED] Shared secret for Next.js → Express server-to-server auth
# The proxy route injects this as a header; the API validates it.
# Generate: openssl rand -hex 32
# Must be identical in apps/web AND apps/api environments.
INTERNAL_API_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX

# [REQUIRED] Shared secret for pipeline → compositor (/api/render) auth
# The Inngest job sends this header; /api/render validates it so only
# authenticated internal callers can use the compositor.
# Generate: openssl rand -hex 32
INTERNAL_RENDER_SECRET=REPLACE_WITH_RANDOM_SECRET

# [REQUIRED] AES-256 key for encrypting OAuth tokens at rest in the DB
# Generate: openssl rand -hex 32  (must be exactly 64 hex chars = 32 bytes)
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# [OPTIONAL] Shared secret for the public POST /contacts/capture webhook
# External callers (LinkedIn lead gen, landing pages) must send this in
# the x-orion-webhook-secret header.
# Generate: openssl rand -hex 32
# Without this: the header check is skipped (OK for local dev, insecure in prod)
ORION_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] PostgreSQL connection string
# Local Docker: postgresql://orion:orion_dev_password@localhost:5432/orion_dev
# Production:   Get from Supabase / Neon dashboard
DATABASE_URL=postgresql://orion:orion_dev_password@localhost:5432/orion_dev


# ═══════════════════════════════════════════════════════════════════════════════
# AI — SERVER-SIDE ONLY
# CRITICAL: Never prefix these with NEXT_PUBLIC_. Never send to the browser.
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED] Anthropic Claude API key — required for all agent operations
# Without this: campaign generation, content creation, optimization, CRM scoring
#               all fail entirely. The pipeline cannot run.
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# [OPTIONAL] Brave Search API key — used by the strategy agent for competitor research
# Without this: strategy agent skips web research and relies on model knowledge only
# Get from: https://api.search.brave.com/app/keys
BRAVE_SEARCH_API_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# IMAGE GENERATION — SERVER-SIDE ONLY
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Fal.ai API key — primary image generation (Flux Dev model)
# Without this: falls back to Pollinations.ai (free, no key needed), then to
#               branded gradient backgrounds if Pollinations also fails.
# Get from: https://fal.ai/dashboard → API Keys
FAL_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# DEV SHORTCUTS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Skip image generation and compositing in the pipeline.
# When set to "1", the pipeline goes straight from content creation to
# mark-campaign-ready, completing in ~30 seconds instead of 2+ minutes.
# Useful when iterating on strategy/copy and visuals aren't needed yet.
# Never set this in production — images will not be generated for any campaign.
# DEV_SKIP_IMAGES=1


# ═══════════════════════════════════════════════════════════════════════════════
# INNGEST (BACKGROUND JOBS / PIPELINE)
# Without Inngest running, the pipeline, publishing cron, and analytics jobs
# will not execute. This is the most common source of "pipeline never starts" bugs.
# ═══════════════════════════════════════════════════════════════════════════════

# [REQUIRED for local dev] Routes Inngest events to localhost:8288 instead of Inngest Cloud.
# MUST be set in ALL .env.local files: root, apps/api, and apps/web.
# Without this: inngest.send() silently routes to Inngest Cloud and the local
#               pipeline never runs. This is the #1 source of dev confusion.
INNGEST_DEV=1

# [OPTIONAL] Inngest event key — "local" works for local dev server
# Required in production: get from Inngest Cloud dashboard
INNGEST_EVENT_KEY=local

# [OPTIONAL] Inngest webhook signing key — only needed in production
# Without this: webhook signature verification is skipped (OK for dev)
INNGEST_SIGNING_KEY=


# ═══════════════════════════════════════════════════════════════════════════════
# REDIS (CACHING & RATE LIMITING)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Redis connection URL — used for AI conversation state and rate limiting
# Local Docker: redis://:orion_redis_password@localhost:6379
# Without this: in-memory fallback used (state lost on restart, no distributed rate limiting)
REDIS_URL=redis://:orion_redis_password@localhost:6379

# [OPTIONAL] Upstash REST Redis — serverless alternative to REDIS_URL
# Without this: falls back to REDIS_URL, then in-memory
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ═══════════════════════════════════════════════════════════════════════════════
# STORAGE (SUPABASE or AWS S3)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Required Supabase buckets (create manually in the Supabase dashboard):
#   logos   — org logos uploaded via brand kit (public access: ON)
#   assets  — Fal.ai / Pollinations generated images (public access: ON)
#   uploads — user source photos for vision analysis (public access: ON)
#             Anthropic vision API requires public HTTPS URLs.
#
# Without storage: logo uploads and image saves fall back to local filesystem.
# This breaks in multi-instance production deployments.

# [RECOMMENDED] Supabase project URL and service key
# Without these: org logo uploads fail; generated images can't be saved to cloud
# Get from: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Alias — set to the same value as SUPABASE_SERVICE_ROLE_KEY
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# [OPTIONAL] Storage bucket name (default: orion-assets)
STORAGE_BUCKET=orion-assets

# [OPTIONAL] AWS S3 alternative to Supabase
# Without these: Supabase storage is used; if Supabase also unconfigured, local disk
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1


# ═══════════════════════════════════════════════════════════════════════════════
# BILLING (STRIPE)
# ═══════════════════════════════════════════════════════════════════════════════

# [RECOMMENDED] Stripe API keys
# Without these: billing page shows no plan info; no upgrade path; free tier only
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# [RECOMMENDED] Stripe webhook secret — validates webhook signatures
# Without this: Stripe webhook events are ignored (subscription changes not applied)
# Get from: Stripe dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# [RECOMMENDED] Stripe Price IDs — create recurring prices in the Stripe dashboard
# Without these: checkout session creation fails (no plan to subscribe to)
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...


# ═══════════════════════════════════════════════════════════════════════════════
# EMAIL (RESEND)
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Resend API key — used for email channel publishing and campaign digests
# Without this: email channel posts are simulated (not sent); post-campaign digest
#               email is skipped silently
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# [OPTIONAL] Sender email address
# Without this: defaults to noreply@orion.app (may fail SPF/DKIM in production)
EMAIL_FROM=noreply@yourdomain.com


# ═══════════════════════════════════════════════════════════════════════════════
# OAUTH — LOGIN PROVIDERS
# Without these: only email/password login is available
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Google OAuth — https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# [OPTIONAL] GitHub OAuth — https://github.com/settings/developers
# Redirect URI: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# ═══════════════════════════════════════════════════════════════════════════════
# OAUTH — SOCIAL PUBLISHING
# Without these: the corresponding social channels are simulated.
# Content is generated but not actually posted to the platform.
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] LinkedIn — https://developer.linkedin.com/
# Scopes needed: w_member_social, r_basicprofile, r_organization_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# [OPTIONAL] X / Twitter — https://developer.x.com/
# OAuth 2.0 with PKCE. Scopes: tweet.write, tweet.read, users.read, offline.access
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# [OPTIONAL] Twitter bearer token — for read-only API operations
TWITTER_BEARER_TOKEN=

# [OPTIONAL] Meta (Facebook + Instagram) — https://developers.facebook.com/
# Permissions: pages_manage_posts, instagram_basic, instagram_content_publish
META_APP_ID=
META_APP_SECRET=

# [OPTIONAL] TikTok — https://developers.tiktok.com/
# Without this: TikTok is content-only (copy provided for manual posting)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=


# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING & ANALYTICS
# ═══════════════════════════════════════════════════════════════════════════════

# [OPTIONAL] Sentry — error tracking and performance monitoring
# Without this: errors are logged to stdout only; no alerting or issue grouping
# Get from: https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Transaction sampling rate (0.0–1.0). Default: 0.1 = 10% of transactions.
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development

# [OPTIONAL] PostHog — product analytics
# Without this: no user behavior tracking or feature flag support
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com


# ═══════════════════════════════════════════════════════════════════════════════
# PLAN LIMITS (ADVANCED — OPTIONAL OVERRIDES)
# Hard-coded defaults live in apps/api/src/lib/usage.ts.
# Uncomment to override for local testing of different plan tiers.
# ═══════════════════════════════════════════════════════════════════════════════

# PLAN_TOKEN_LIMIT_FREE=50000
# PLAN_TOKEN_LIMIT_PRO=500000
# PLAN_POST_LIMIT_FREE=50
# PLAN_POST_LIMIT_PRO=500
