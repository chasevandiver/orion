# =============================================================================
# ORION AI Marketing OS — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Internal API URL — used by Next.js server components to call the Express API
# In production, set to the internal service hostname (avoids public internet roundtrip)
INTERNAL_API_URL=http://localhost:3001
API_URL=http://localhost:3001
NODE_ENV=development

# Shared secret for internal server-to-server requests (e.g., Inngest pipeline → compositor).
# The Inngest job sends this header; the /api/render route validates it so only
# authenticated internal callers can use the compositor.
# Generate with: openssl rand -hex 32
# Add the same value to .env.local
INTERNAL_RENDER_SECRET=REPLACE_WITH_RANDOM_SECRET

# Shared secret for Next.js → Express header-injection auth path.
# Must be identical in apps/web and apps/api environments.
# Generate with: openssl rand -hex 32
# If unset, the check is skipped (safe for local dev without the var configured).
INTERNAL_API_SECRET=REPLACE_WITH_RANDOM_32_CHAR_HEX

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker: postgresql://orion:orion_dev_password@localhost:5432/orion_dev
# Production: Get from Supabase / Neon dashboard
DATABASE_URL=postgresql://orion:orion_dev_password@localhost:5432/orion_dev

# ── AI — SERVER SIDE ONLY. Never prefix with NEXT_PUBLIC_ ────────────────────
# CRITICAL: This key must NEVER reach the browser.
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Fal.ai — image generation (Flux Schnell)
# Get from: https://fal.ai/dashboard → API Keys
FAL_KEY=

# ── Auth (next-auth) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker: redis://:orion_redis_password@localhost:6379
# Production: Get from Upstash dashboard
REDIS_URL=redis://:orion_redis_password@localhost:6379

# Upstash (for rate limiting in serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Queue (Inngest) ───────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe dashboard
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── Platform Integrations ─────────────────────────────────────────────────────
# LinkedIn — https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X / Twitter — https://developer.x.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# Meta (Facebook + Instagram) — https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=

# TikTok — https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Token Encryption ──────────────────────────────────────────────────────────
# Used to encrypt OAuth tokens at rest in the database.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# ── Analytics ────────────────────────────────────────────────────────────────
# PostHog (optional — for product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Storage (Supabase / S3) ───────────────────────────────────────────────────
STORAGE_BUCKET=orion-assets
# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Alias used by the API and queue packages (same value as SUPABASE_SERVICE_ROLE_KEY)
SUPABASE_SERVICE_KEY=
#
# Required Supabase Storage buckets (create manually in the Supabase dashboard):
#   "logos"   — org logos uploaded via brand kit (public access ON)
#   "assets"  — Fal.ai generated images written by the pipeline (public access ON)
#   "uploads" — user-uploaded source photos (public access ON, required for
#               Anthropic vision API which only accepts public HTTPS URLs)
# Or AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Get from: https://sentry.io → Project → Settings → Client Keys (DSN)
# Both server and browser DSNs are needed for full coverage
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Sampling rate: 0.0–1.0 (default 0.1 = 10% of transactions traced)
SENTRY_TRACES_SAMPLE_RATE=0.1
# Set to "production" in prod deployments
SENTRY_ENVIRONMENT=development

# ── Webhook Capture ───────────────────────────────────────────────────────────
# Shared secret for the public POST /contacts/capture endpoint.
# External callers (LinkedIn lead gen, email platforms, landing pages) must send
# this value in the x-orion-webhook-secret request header.
# Generate with: openssl rand -hex 32
# If unset, the header check is skipped (convenient for local dev).
ORION_WEBHOOK_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Phase 4: Plan limits (token quotas, post limits) ─────────────────────────
# These are hard-coded defaults in apps/api/src/lib/usage.ts but can be
# overridden here if you want to test different limits locally:
# PLAN_TOKEN_LIMIT_FREE=50000
# PLAN_TOKEN_LIMIT_PRO=500000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
