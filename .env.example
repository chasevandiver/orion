# =============================================================================
# ORION AI Marketing OS — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local Docker: postgresql://orion:orion_dev_password@localhost:5432/orion_dev
# Production: Get from Supabase / Neon dashboard
DATABASE_URL=postgresql://orion:orion_dev_password@localhost:5432/orion_dev

# ── AI — SERVER SIDE ONLY. Never prefix with NEXT_PUBLIC_ ────────────────────
# CRITICAL: This key must NEVER reach the browser.
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth (next-auth) ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local Docker: redis://:orion_redis_password@localhost:6379
# Production: Get from Upstash dashboard
REDIS_URL=redis://:orion_redis_password@localhost:6379

# Upstash (for rate limiting in serverless)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Queue (Inngest) ───────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create in Stripe dashboard
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── Platform Integrations ─────────────────────────────────────────────────────
# LinkedIn — https://developer.linkedin.com/
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# X / Twitter — https://developer.x.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_BEARER_TOKEN=

# Meta (Facebook + Instagram) — https://developers.facebook.com/
META_APP_ID=
META_APP_SECRET=

# TikTok — https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# ── Token Encryption ──────────────────────────────────────────────────────────
# Used to encrypt OAuth tokens at rest in the database.
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX_STRING

# ── Analytics ────────────────────────────────────────────────────────────────
# PostHog (optional — for product analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── Storage (Supabase / S3) ───────────────────────────────────────────────────
STORAGE_BUCKET=orion-assets
# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Or AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Error Monitoring ──────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
